# Copy to mcp-server/.env (gitignored) and fill in. config.ts reads this file.

# Port for the Streamable-HTTP MCP plane (/mcp) and the web plane (/state, /health).
PORT=3101

# CRITICAL COUPLING — the HTTPS base the PCF and the agent reach this server at.
# It MUST equal the PCF control's `serverBaseUrl` property AND the manifest
# `external-service-usage` domain. `http://localhost` is silently blocked as MIXED CONTENT inside the
# HTTPS Power App, so run this server behind an HTTPS devtunnel and paste that base here, e.g.:
#   devtunnel host -p 3101 --allow-anonymous
#   PUBLIC_BASE_URL=https://<id>-3101.<region>.devtunnels.ms
PUBLIC_BASE_URL=http://localhost:3101

# Capability token gating GET /state (the shared-state read). Generate a long random string.
STATE_KEY=change-me-to-a-long-random-string

# Optional: CSP frame-ancestors for any component pages you serve that Power Apps will iframe.
# FRAME_ANCESTORS=https://*.dynamics.com 'self'

# Optional overrides.
# STATE_FILE=state.json
# LOG_LEVEL=info
# LOG_DIR=logs
